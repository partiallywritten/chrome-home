{
  "manifest_version": 3,
  "name": "Nozy-NT",
  "version": "1.0.0",
  "description": "A minimal custom new tab page with time, favorite sites, and a customizable background.",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["storage", "unlimitedStorage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
